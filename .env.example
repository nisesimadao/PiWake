# Browser-visible API path. Do not put secrets in VITE_* variables.
# Production builds default to the same-origin API even without this.
VITE_PIWAKE_API_URL=/piwake-api

# Force demo mode in a production build (UI only, no network calls).
# VITE_PIWAKE_MODE=demo

# Development-server-only proxy target, e.g. the Raspberry Pi Tailscale URL.
PIWAKE_PROXY_TARGET=http://100.100.1.1:8787
